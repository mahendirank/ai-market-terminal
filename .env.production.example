# Copy this file to .env and fill in real values BEFORE first deploy.
# Never commit .env to git.

# ─── REQUIRED ─────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
ADMIN_PASSWORD=set-a-strong-random-password-here

# ─── INFRASTRUCTURE ───────────────────────────────────────────────
TZ=Asia/Kolkata

# ─── LOGGING (Sprint 2 Phase A) ───────────────────────────────────
# Root logger level. DEBUG enables the silent log.debug() calls in
# ai_router, regime_engine, etc. Default INFO preserves current behavior.
LOG_LEVEL=INFO

# Formatter for stdout. "console" (default) is human-readable text with
# request-id prefix — visually similar to pre-Sprint-2 output.
# "json" emits one-JSON-line-per-record suitable for grep/jq and a future
# log shipper (Loki / CloudWatch).
LOG_FORMAT=console

# Per-HTTP-request log line via RequestContextMiddleware. When true (default),
# every request emits a structured "request_complete" log with method, path,
# status, and duration_ms. Set to false to silence (request_id header and
# context-var propagation still work).
LOG_HTTP_REQUESTS=true

# Uvicorn's built-in plain-text access log. Default "off" because our
# middleware produces the structured equivalent — set to "on" if you want
# both. Setting "on" doubles per-request log volume.
UVICORN_ACCESS_LOG=off

# ─── ORCHESTRATION (Sprint 4 — DEFAULTS ALL DISABLED) ─────────────
# AGENT_ORCHESTRATOR_ENABLED: master gate for the orchestration runtime.
# When false (default), FastAPI boots identically to pre-Sprint-4. No
# Orchestrator is constructed, no Redis client created for events.
# Admin endpoints (/api/agents, /api/circuits, /api/streams/health) all
# return {"enabled": false, ...} so they are safe to expose either way.
AGENT_ORCHESTRATOR_ENABLED=false

# Event bus selection. Honored only when AGENT_ORCHESTRATOR_ENABLED=true.
#   auto   (default) — REDIS_URL set → use Redis; else fall back to in-memory
#   redis  — require REDIS_URL; refuse to silently fall back
#   memory — always in-memory (suitable when no agents need durability)
AGENT_BUS=auto

# Redis URL for the event bus. Default uses the existing redis service.
# Currently also used by signal_memory, alert_engine, etc. — already wired.
REDIS_URL=redis://redis:6379/0

# Per-agent auto-DISABLE threshold (consecutive tick failures). Hard min 1.
# Default 5 = a busy agent gets ~5 minutes of margin before self-disabling.
AGENT_MAX_FAILURES=5

# ─── Stage 4.3: NewsFetchAgent (SHADOW / DUAL-RUN — DEFAULT OFF) ──
# When true (only flip AFTER 24h clean soak with AGENT_ORCHESTRATOR_ENABLED=true):
#   - NewsFetchAgent registers + starts in the orchestrator
#   - Agent wraps the legacy news.get_all_news() via asyncio.to_thread
#   - Agent emits news.raw events to the bus (no consumer yet)
#   - Legacy pipeline UNCHANGED and authoritative
#   - Agent failures do NOT cascade to production paths
AGENT_NEWS_FETCH_ENABLED=false

# Agent tick cadence (seconds). Default 120s = halve the cache-miss
# pressure during dual-run. Reduce to 60s after observation, or raise
# to 180s if external API rate limits become a concern.
NEWS_FETCH_TICK_INTERVAL=120

# Per-tick wall-clock cap. Should comfortably exceed worst observed
# legacy fetch time. Default 30s.
NEWS_FETCH_TIMEOUT=30

# ─── Stage 4.4: SignalCriticAgent (OBSERVE-ONLY — DEFAULT OFF) ──
# When true:
#   - Agent consumes events:signal:candidate (Sprint 5 will add producer)
#   - Evaluates Schema + ConfidenceFloor + RecentBar deterministic critics
#   - Logs `signal_critic_observed` with verdict + emits `signal.critique`
#     events to a separate stream (metadata only — NO original signal data)
#   - NEVER rejects, NEVER DLQs, NEVER blocks the candidate event
#   - Fail-open on any critic chain exception
#
# Sprint 4.4: agent runs idle (no producer). Sprint 5+: producer added,
# verdicts begin populating. Enforcement is a separate flag (does NOT
# exist yet) — observe-mode is permanent for Sprint 4.
AGENT_SIGNAL_CRITIC_ENABLED=false

# ─── OPTIONAL (paid data) ─────────────────────────────────────────
TWELVEDATA_API_KEY=
POLYGON_API_KEY=

# ─── ALERT THRESHOLDS (tune to your client base) ──────────────────
ALERT_VIX_SPIKE_PCT=15
ALERT_VIX_ABS_LEVEL=25
ALERT_GOLD_PCT=0.8
ALERT_YIELD_SHOCK_PCT=0.5
ALERT_DXY_PCT=0.4
ALERT_COOLDOWN_SECS=3600
ALERT_MIN_CONF=80
ALERT_DISABLED=false
