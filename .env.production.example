# Copy this file to .env and fill in real values BEFORE first deploy.
# Never commit .env to git.

# ─── REQUIRED ─────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here
ADMIN_PASSWORD=set-a-strong-random-password-here

# ─── INFRASTRUCTURE ───────────────────────────────────────────────
TZ=Asia/Kolkata

# ─── LOGGING (Sprint 2 Phase A) ───────────────────────────────────
# Root logger level. DEBUG enables the silent log.debug() calls in
# ai_router, regime_engine, etc. Default INFO preserves current behavior.
LOG_LEVEL=INFO

# Formatter for stdout. "console" (default) is human-readable text with
# request-id prefix — visually similar to pre-Sprint-2 output.
# "json" emits one-JSON-line-per-record suitable for grep/jq and a future
# log shipper (Loki / CloudWatch).
LOG_FORMAT=console

# Per-HTTP-request log line via RequestContextMiddleware. When true (default),
# every request emits a structured "request_complete" log with method, path,
# status, and duration_ms. Set to false to silence (request_id header and
# context-var propagation still work).
LOG_HTTP_REQUESTS=true

# Uvicorn's built-in plain-text access log. Default "off" because our
# middleware produces the structured equivalent — set to "on" if you want
# both. Setting "on" doubles per-request log volume.
UVICORN_ACCESS_LOG=off

# ─── OPTIONAL (paid data) ─────────────────────────────────────────
TWELVEDATA_API_KEY=
POLYGON_API_KEY=

# ─── ALERT THRESHOLDS (tune to your client base) ──────────────────
ALERT_VIX_SPIKE_PCT=15
ALERT_VIX_ABS_LEVEL=25
ALERT_GOLD_PCT=0.8
ALERT_YIELD_SHOCK_PCT=0.5
ALERT_DXY_PCT=0.4
ALERT_COOLDOWN_SECS=3600
ALERT_MIN_CONF=80
ALERT_DISABLED=false
